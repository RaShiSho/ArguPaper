# MinerU API
MINERU_API_KEY=your_api_key_here
MINERU_API_ENDPOINT=https://api.mineru.cn/v1/convert

# Ngrok/Tunnel URL (for exposing local server to MinerU API)
# Set this when using ngrok to expose local server
NGROK_URL_BASE=https://your-ngrok-url.ngrok-free.dev

# Semantic Scholar
SEMANTIC_SCHOLAR_API_KEY=your_api_key_here

# Storage
DATA_PATH=./data
CACHE_PATH=./data/cache
PAPER_STORAGE_PATH=./data/papers

# Model Configuration
LLM_MODEL=claude-3-5-sonnet-20241022
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# Debate Configuration
DEBATE_MAX_ROUNDS=3