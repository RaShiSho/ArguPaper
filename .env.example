# MinerU API
MINERU_API_KEY=your_api_key_here
MINERU_API_ENDPOINT=https://api.mineru.cn/v1/convert

# Ngrok/Tunnel URL (for exposing local server to MinerU API)
# Set this when using ngrok to expose local server
NGROK_URL_BASE=https://your-ngrok-url.ngrok-free.dev

# Semantic Scholar
SEMANTIC_SCHOLAR_API_KEY=your_api_key_here

# Storage
DATA_PATH=./data
CACHE_PATH=./data/cache
PAPER_STORAGE_PATH=./data/papers

# Model Configuration
LLM_MODEL=claude-3-5-sonnet-20241022
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
LLM_DEFAULT_PROVIDER=default
LLM_WEAK_PROVIDER=weak

# OpenAI-compatible Providers
LLM_PROVIDER__DEFAULT__BASE_URL=https://api.openai.com/v1
LLM_PROVIDER__DEFAULT__API_KEY=your_default_provider_api_key_here
LLM_PROVIDER__DEFAULT__MODEL=gpt-4o-mini
LLM_PROVIDER__WEAK__BASE_URL=https://api.openai.com/v1
LLM_PROVIDER__WEAK__API_KEY=your_weak_provider_api_key_here
LLM_PROVIDER__WEAK__MODEL=gpt-4o-mini

# Search Agent
SEARCH_AGENT_TRACE_PATH=./data/agent_runs/search
SEARCH_AGENT_MAX_CANDIDATES=50

# Debate Configuration
DEBATE_MAX_ROUNDS=3
